# Optional: checkout-time UPS shipping estimator trained from historical
# Unishippers actual shipment costs joined to QuickBooks order facts. This is
# separate from WWEX live rating because checkout does not yet know final box
# count, dry ice, or packed weights. Keep disabled until a trained
# shipping_cost_forecast_v2 model has been reviewed and installed.
GRILLERS_SHIPPING_FORECAST_ENABLED=false
GRILLERS_SHIPPING_FORECAST_MODEL_PATH=
# Optional charge-policy controls (safe defaults; only used when the forecast is enabled):
#   SAFETY_PERCENTILE: p50 | p75 (default) | p90 — margin buffer added on top of
#     the mean prediction (the matching absolute training residual).
#   MIN_USD / MAX_USD: sanity rails. A forecast (after buffer) outside the band,
#     or any non-positive point estimate, is treated as non-confident and falls
#     through to WWEX live rating, then the Strapi tier table. MIN_USD defaults to
#     $5 when blank (no real UPS small-parcel costs less); set 0 to disable, or a
#     higher per-service floor before going live. MAX_USD blank = disabled.
GRILLERS_SHIPPING_FORECAST_SAFETY_PERCENTILE=p75
GRILLERS_SHIPPING_FORECAST_MIN_USD=
GRILLERS_SHIPPING_FORECAST_MAX_USD=
# v3 GBM model (data/shipping-cost-forecast-gbm.json) cushion + rollout controls:
#   SHADOW=true  -> watch-only: the forecast is computed and logged but does NOT set
#     the customer's price (falls through to live WWEX/Strapi). Use for a pilot week,
#     then set to false to go live.
#   MARKUP -> multiplicative cushion (default baked into the model, 1.20 = "20% buffer").
#     Overrides the model default. A markup model uses no additive buffer by default.
GRILLERS_SHIPPING_FORECAST_SHADOW=true
GRILLERS_SHIPPING_FORECAST_MARKUP=

# Optional: enable actual shipment booking and label retrieval after final
# pre-shipment charge succeeds. Keep disabled until production bill-to details
# and staff label handling are verified.
WWEX_BILL_TO_ACCOUNT_NBR=
WWEX_BILL_TO_POSTAL_CODE=
WWEX_BILL_TO_COUNTRY_CODE=US
WWEX_BILL_TO_TYPE=SENDER
WWEX_BOOK_SHIPMENTS_ON_RELEASE=false
WWEX_FETCH_LABEL_ON_RELEASE=true
WWEX_NOTIFICATION_EMAIL=

# Ops alerts → gp-analytics ingestion pipe (grillers_pride.events, ops_alert).
# Money/integrity alerts (refund mismatch, charge-PI gate, post-ship charge
# failure, blocked allocations) POST here; the ops-pager polls and routes page/
# warn alerts to Slack. Without these, emitOpsAlert() no-ops with a logged skip.
GP_ANALYTICS_ENDPOINT=
GP_ANALYTICS_SERVER_KEY=

# Final-charge money-integrity guard. The flow already BLOCKS the transition to
# charged_ready_to_ship for any non-succeeded PaymentIntent (the assert throws),
# and pages charge_marked_ready_but_pi_not_succeeded. This flag is an opt-in
# reserved for a future relaxed-assert path; default false keeps current
# behavior (alert + block via assert).
GRILLERS_BLOCK_NONSUCCEEDED_CHARGE=false

# Stripe webhook signing secret for /webhooks/stripe/payment-failed. Configure a
# Stripe dashboard webhook to https://<medusa-admin-host>/webhooks/stripe/
# payment-failed for event payment_intent.payment_failed, and put the signing
# secret (whsec_…) here. If unset, the route accepts unsigned webhooks (dev only)
# and logs a warning.
STRIPE_WEBHOOK_SECRET=

# Slack signing secret for the `/gp` slash-command query bot
# (POST /webhooks/slack/command). In the Slack app config, point the slash
# command's Request URL at:
#   https://<medusa-admin-host>/webhooks/slack/command
# and copy the app's "Signing Secret" (Basic Information page) here. This is the
# ONLY gate on that endpoint, so the route FAILS CLOSED when it is unset: every
# request is rejected unless the dev opt-in below is set.
SLACK_SIGNING_SECRET=

# Dev-only escape hatch: accept UNSIGNED /webhooks/slack/command requests when
# SLACK_SIGNING_SECRET is unset. Ignored in production (NODE_ENV=production). Use
# only for local testing; never set this in a deployed environment.
SLACK_ALLOW_UNSIGNED=

# ── /gp caller authorization (who may run order/customer/stock; PII gate) ──
# The data subcommands are restricted to Grillers Pride STAFF — the same people
# who can log into the Medusa admin (the core Medusa `user` module). `help` is
# open to everyone.
#
# PREFERRED (identity-based): set a Slack BOT token whose app has the
# `users:read.email` OAuth scope. The route resolves the caller's email via
# Slack users.info and checks it against the live set of Medusa admin users.
# Active when SLACK_BOT_TOKEN is set AND both allowlists below are empty.
SLACK_BOT_TOKEN=
#
# FALLBACK (allowlist): if `users:read.email` isn't granted yet, authorize by
# Slack id instead. Comma-separated. If EITHER is set it takes precedence over
# the identity path (so you can ship before adding the scope). If NEITHER a bot
# token NOR an allowlist is set, every data subcommand is DENIED (fail closed).
SLACK_GP_ALLOWED_USER_IDS=
SLACK_GP_ALLOWED_CHANNEL_IDS=
