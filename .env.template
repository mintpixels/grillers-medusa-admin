# Optional: checkout-time UPS shipping estimator trained from historical
# Unishippers actual shipment costs joined to QuickBooks order facts. This is
# separate from WWEX live rating because checkout does not yet know final box
# count, dry ice, or packed weights. Keep disabled until a trained
# shipping_cost_forecast_v2 model has been reviewed and installed.
GRILLERS_SHIPPING_FORECAST_ENABLED=false
GRILLERS_SHIPPING_FORECAST_MODEL_PATH=
# Optional charge-policy controls (safe defaults; only used when the forecast is enabled):
#   SAFETY_PERCENTILE: p50 | p75 (default) | p90 — margin buffer added on top of
#     the mean prediction (the matching absolute training residual).
#   MIN_USD / MAX_USD: sanity rails. A forecast (after buffer) outside the band,
#     or any non-positive point estimate, is treated as non-confident and falls
#     through to WWEX live rating, then the Strapi tier table. MIN_USD defaults to
#     $5 when blank (no real UPS small-parcel costs less); set 0 to disable, or a
#     higher per-service floor before going live. MAX_USD blank = disabled.
GRILLERS_SHIPPING_FORECAST_SAFETY_PERCENTILE=p75
GRILLERS_SHIPPING_FORECAST_MIN_USD=
GRILLERS_SHIPPING_FORECAST_MAX_USD=
# v3 GBM model (data/shipping-cost-forecast-gbm.json) cushion + rollout controls:
#   SHADOW=true  -> watch-only: the forecast is computed and logged but does NOT set
#     the customer's price (falls through to live WWEX/Strapi). Use for a pilot week,
#     then set to false to go live.
#   MARKUP -> multiplicative cushion (default baked into the model, 1.20 = "20% buffer").
#     Overrides the model default. A markup model uses no additive buffer by default.
GRILLERS_SHIPPING_FORECAST_SHADOW=true
GRILLERS_SHIPPING_FORECAST_MARKUP=

# Optional: enable actual shipment booking and label retrieval after final
# pre-shipment charge succeeds. Keep disabled until production bill-to details
# and staff label handling are verified.
WWEX_BILL_TO_ACCOUNT_NBR=
WWEX_BILL_TO_POSTAL_CODE=
WWEX_BILL_TO_COUNTRY_CODE=US
WWEX_BILL_TO_TYPE=SENDER
WWEX_BOOK_SHIPMENTS_ON_RELEASE=false
WWEX_FETCH_LABEL_ON_RELEASE=true
WWEX_NOTIFICATION_EMAIL=
